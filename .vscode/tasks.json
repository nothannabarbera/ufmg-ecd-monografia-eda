{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Quarto: Render and Preview",
      "type": "shell",
      "command": "${workspaceFolder}/preview.sh",
      "args": ["${file}"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Quarto: Render",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "source .venv/bin/activate && quarto render ${file}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
